{
  "display_information": {
      "name": "Vecna",
      "description": "Context-aware Slack agent powered by Gemini and Real-Time Search",
      "background_color": "#485ea1"
  },
  "features": {
      "app_home": {
          "home_tab_enabled": false,
          "messages_tab_enabled": true,
          "messages_tab_read_only_enabled": false
      },
      "bot_user": {
          "display_name": "Vecna Search Agent",
          "always_online": true
      },
      "agent_view": {
          "agent_description": "I search your workspace to disambiguate people, channels, and topics, then resolve answers from Slack conversations.",
          "suggested_prompts": [
              {
                  "title": "Find a conversation",
                  "message": "Where did we leave off discussing the database migration?"
              },
              {
                  "title": "Look up a person",
                  "message": "Who is Jason on the analytics team?"
              }
          ]
      }
  },
  "oauth_config": {
      "scopes": {
          "bot": [
              "app_mentions:read",
              "assistant:write",
              "channels:history",
              "chat:write",
              "groups:history",
              "im:history",
              "mpim:history",
              "reactions:read",
              "reactions:write",
              "search:read.public",
              "search:read.files",
              "search:read.users"
          ]
      },
      "pkce_enabled": false
  },
  "settings": {
      "event_subscriptions": {
          "bot_events": [
              "app_context_changed",
              "app_home_opened",
              "message.im"
          ]
      },
      "interactivity": {
          "is_enabled": true
      },
      "org_deploy_enabled": true,
      "socket_mode_enabled": true,
      "token_rotation_enabled": false,
      "is_mcp_enabled": false
  }
}